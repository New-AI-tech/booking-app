rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // User Profiles: Only authenticated users can create their own profile, and read/update their own profile.
    match /users/{userId} {
      allow create: if isAuthenticated() && request.auth.uid == userId;
      allow read, update: if isOwner(userId);
    }

    // Dresses: Anyone can read, only Admins can write
    match /dresses/{dressId} {
      allow read: if true;
      allow write: if isAuthenticated() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Inventory Items: Anyone can read, only Admins can write
    match /inventory_items/{itemId} {
      allow read: if true;
      allow write: if isAuthenticated() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Reservations: Authenticated users can create, read their own, and staff/admin can read/update all.
    match /reservations/{reservationId} {
      allow create: if isAuthenticated() && request.resource.data.customerEmail == request.auth.token.email;
      allow read: if isOwner(resource.data.customerEmail) || (isAuthenticated() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['staff', 'admin']);
      allow update, delete: if isAuthenticated() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
  }
}
